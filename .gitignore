# =========================
# Unity / C# .gitignore
# =========================

# OS / Editor junk
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/
[Rr]ecordings/
UserSettings/

# Visual Studio / Rider / VS Code
.vs/
.vscode/
.idea/
*.suo
*.user
*.userprefs
*.csproj
*.sln
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.VC.VC.opendb

# Unity crash reports
sysinfo.txt

# Asset meta caches
*.tmp
*.bak

# Unity Addressables / Streaming (keep StreamingAssets if you use it)
# [Ss]treamingAssets/aa/  # uncomment if you use Addressables and don't want generated content

# IL2CPP / Burst / Bee
[Bb]ee/
[Bb]eeartifacts/
.il2cpp/
**/il2cpp_cache/
**/BurstDebugInformation_DoNotShip/
**/BurstDebugInformation*

# Gradle / Android (if you ever switch platforms)
.gradle/
**/gradleOut/
**/AndroidBuild/
**/*.apk
**/*.aab

# Build output / executable artifacts (do NOT commit)
*.exe
*.dll
*.pdb
*.mdb
*.app
*.dmg
*.zip
*.7z

# Unity Package Manager cache
**/PackageCache/

# Lighting / GI cache 
**/[Ll]ightingData.asset
**/[Ll]ightingData.asset.meta
**/[Ll]ightmap*.exr
**/[Ll]ightmap*.png
**/[Ll]ightmap*.tga

